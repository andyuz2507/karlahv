generator client {
  provider = "prisma-client-js"
}

// Run: npx prisma db push  (or migrate)
// Run: npx prisma db seed

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

model File {
  id        String   @id @default(cuid())
  filename  String
  path      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

// Espacios disponibles recurrentes (semanal o quincenal)
model AvailabilitySlot {
  id          String   @id @default(cuid())
  dayOfWeek   Int      @map("day_of_week")  // 0=domingo, 1=lunes, ..., 6=sábado
  startTime   String   @map("start_time")   // "09:00"
  endTime     String   @map("end_time")     // "10:00"
  frequency   String   // "weekly" | "biweekly"
  biweekGroup Int?     @map("biweek_group") // 0 o 1 para quincenal
  createdAt   DateTime @default(now())      @map("created_at")

  @@map("availability_slot")
}

// Solicitudes de reserva de pacientes potenciales
model BookingRequest {
  id          String   @id @default(cuid())
  nombre      String
  celular     String
  email       String
  paraQuien   String   @map("para_quien")
  descripcion String
  modalidad   String
  temporalidad String
  slotDate    String   @map("slot_date")
  slotTime    String   @map("slot_time")
  referencia  String?  // A quién le agradezco la recomendación (opcional)
  status      String   @default("pendiente")
  notas       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("booking_request")
}
