generator client {
  provider = "prisma-client-js"
}

// Run: npx prisma db push  (or migrate)
// Run: npx prisma db seed

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

model File {
  id        String   @id @default(cuid())
  filename  String
  path      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

// Espacios disponibles recurrentes (semanal o quincenal)
model AvailabilitySlot {
  id         String   @id @default(cuid())
  dayOfWeek  Int      // 0=domingo, 1=lunes, ..., 6=sábado
  startTime  String   // "09:00"
  endTime    String   // "10:00"
  frequency  String   // "weekly" | "biweekly"
  biweekGroup Int?    // 0 o 1 para quincenal (semana par/impar del año)
  createdAt  DateTime @default(now())
}

// Solicitudes de reserva de clientes potenciales
model BookingRequest {
  id          String   @id @default(cuid())
  nombre      String
  celular     String
  email       String
  paraQuien   String   // para quién es la terapia
  descripcion String
  modalidad   String   // "fisico" | "remoto"
  temporalidad String  // "semanal" | "quincenal"
  slotDate    String   // "2025-03-17"
  slotTime    String   // "09:00"
  status      String   @default("pendiente") // pendiente, contactado, agendada, cancelada
  notas       String?  // notas internas para follow-up
  createdAt   DateTime @default(now())
}
